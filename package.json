{
  "name": "tight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite dev\" \"tsx watch src/lib/ws/dev-server.ts\"",
    "build": "vite build",
    "start": "node --env-file=.env --import tsx/esm server.ts",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed-sample": "tsx scripts/seed-sample.ts",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.30.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "tsx": "^4.19.0",
    "@auth/sveltekit": "^1.7.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.0",
    "nanoid": "^5.0.0",
    "ws": "^8.18.0"
  },
  "type": "module"
}
